    "func": "const cmd = (msg.payload || '').toString().toLowerCase().trim();\nconst cur  = flow.get('relay_vic_2') || false;\nconst next = cmd === 'toggle' ? !cur\n           : (cmd === '1' || cmd === 'on' || cmd === 'an' || cmd === 'true');\nmsg.payload = next ? 1 : 0;\nreturn msg;",
