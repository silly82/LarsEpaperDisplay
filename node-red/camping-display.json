  {
    "id": "camp_fn_mppt_agg",
    "type": "function",
    "z": "camp_tab_main",
    "g": "camp_c_c1",
    "name": "Aggregator → JSON",
    "func": "flow.set('mppt_' + msg.field, msg.payload);\n\nconst j = {\n    schema: 'camping.telemetry.mppt.v1',\n    ts: new Date().toISOString()\n};\nfor (const f of ['soc', 'voltage', 'solar_w', 'current_a', 'load_w']) {\n    const v = flow.get('mppt_' + f);\n    if (v !== null && v !== undefined) j[f] = v;\n}\n\nmsg.topic   = 'camping/telemetry/mppt';\nmsg.payload = JSON.stringify(j);\nmsg.qos     = 0;\nmsg.retain  = false;\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
