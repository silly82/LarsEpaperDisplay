  {
    "id": "camp_mqtt_in_relay",
    "type": "mqtt in",
    "z": "camp_tab_main",
    "g": "camp_c_b1",
    "name": "Relais cmd",
    "topic": "lars/relais/+/cmd",
    "qos": "1",
    "datatype": "utf8",
    "broker": "camp_broker",
    "nl": false,
    "rap": false,
    "rh": 0,
    "inputs": 0,
    "x": 180,
    "y": 360,
