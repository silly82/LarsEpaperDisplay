  {
    "id": "camp_fn_adapter",
    "type": "function",
    "z": "camp_tab_main",
    "g": "camp_c_a1",
    "name": "JSON → lars/mppt/*",
    "func": "let j = msg.payload;\nif (typeof j === 'string') {\n    try { j = JSON.parse(j); } catch (e) { return null; }\n}\nif (!j || typeof j !== 'object') return null;\n\nconst publish = (topic, value) => {\n    if (value === undefined || value === null || !topic) return;\n    const n = Number(value);\n    if (Number.isNaN(n)) return;\n    node.send({ topic, payload: String(n), qos: 0, retain: false });\n};\n\npublish('lars/mppt/soc', j.soc);\npublish('lars/mppt/batV', j.voltage ?? j.bat_v);\npublish('lars/mppt/solarW', j.solar_w ?? j.solarW);\n/* Optional: in config.h TOPIC_* setzen und hier aktivieren\npublish('lars/mppt/batA', j.current_a);\npublish('lars/mppt/loadW', j.load_w);\npublish('lars/mppt/batTemp', j.temp_c);\n*/\nreturn;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 420,
    "y": 140,
    "wires": [["camp_mqtt_out_flat"]]
  },
  {
    "id": "camp_mqtt_out_flat",
    "type": "mqtt out",
    "z": "camp_tab_main",
    "g": "camp_c_a1",
